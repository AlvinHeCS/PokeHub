# Copy to .env and fill in values. Never commit .env.

# ----- NextAuth -----
# Generate via: npx auth secret
AUTH_SECRET=""

# Google OAuth — https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Comma-separated emails that auto-promote to ADMIN role on sign-in
ADMIN_EMAILS="alvain6767@gmail.com"

# ----- Database (Supabase) -----
# DATABASE_URL: pooled connection (port 6543), used at runtime
DATABASE_URL="postgres://postgres.PROJECTREF:[email protected]:6543/postgres?pgbouncer=true&connection_limit=1"
# DIRECT_URL: direct connection (port 5432), used by Prisma migrations
DIRECT_URL="postgres://postgres.PROJECTREF:[email protected]:5432/postgres"

# ----- Stripe -----
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# ----- Resend -----
RESEND_API_KEY="re_..."
EMAIL_FROM="PokeHub <orders@yourdomain.com>"

# ----- AWS S3 + CloudFront -----
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
S3_BUCKET="pokehub-uploads"
CLOUDFRONT_URL="https://dxxxxxx.cloudfront.net"

# ----- Public site -----
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
